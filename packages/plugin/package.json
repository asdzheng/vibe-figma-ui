{
  "name": "@vibe-figma/plugin",
  "version": "0.9.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "manifest.json", "ui.html"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/plugin-entry.ts --bundle --format=iife --outfile=dist/plugin.js --platform=browser --sourcemap --target=es6",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vibe-figma/capture-core": "workspace:*",
    "@vibe-figma/cli": "workspace:*",
    "@vibe-figma/schema": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.10"
  }
}
