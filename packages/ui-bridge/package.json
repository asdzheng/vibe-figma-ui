{
  "name": "@vibe-figma/ui-bridge",
  "private": true,
  "version": "0.7.0",
  "description": "Archived V1 bridge-first package kept for historical reference only.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibe-figma-bridge": "./bin/vibe-figma-bridge.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.js"
    }
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vibe-figma/schema": "workspace:*",
    "zod": "^4.3.6"
  }
}
