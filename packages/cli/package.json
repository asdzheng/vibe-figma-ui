{
  "name": "@vibe-figma/cli",
  "version": "0.9.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibe-figma": "./bin/vibe-figma.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.js"
    }
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vibe-figma/schema": "workspace:*",
    "zod": "^4.3.6"
  }
}
