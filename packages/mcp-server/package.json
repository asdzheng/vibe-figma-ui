{
  "name": "@vibe-figma/mcp-server",
  "private": true,
  "version": "0.7.0",
  "description": "Archived V1 MCP package kept for historical reference only.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibe-figma-mcp": "./bin/vibe-figma-mcp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vibe-figma/capture-core": "workspace:*",
    "@vibe-figma/fixtures": "workspace:*",
    "@vibe-figma/schema": "workspace:*",
    "@vibe-figma/ui-bridge": "workspace:*",
    "zod": "^4.3.6"
  }
}
