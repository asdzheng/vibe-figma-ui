{
  "name": "vibe-figma-ui",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "cli": "node ./packages/cli/bin/vibe-figma.mjs",
    "dev:cli": "node ./packages/cli/bin/vibe-figma.mjs dev",
    "lint": "eslint .",
    "package:artifacts": "node ./scripts/package-artifacts.mjs",
    "test:e2e:figma": "node ./scripts/figma-e2e-smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.123.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
