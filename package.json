{
  "name": "vibe-figma-ui",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev:bridge": "corepack pnpm --filter @vibe-figma/ui-bridge exec vibe-figma-bridge",
    "dev:mcp": "corepack pnpm --filter @vibe-figma/mcp-server exec vibe-figma-mcp",
    "lint": "eslint .",
    "package:artifacts": "node ./scripts/package-artifacts.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.123.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
